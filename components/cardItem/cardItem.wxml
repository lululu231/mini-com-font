<view 
  class="card card--{{size}} {{customClass}} {{clickable ? 'card--clickable' : ''}}"
  style="{{customStyle}}"
  bind:tap="handleClick"
>
  <image 
    class="card-img" 
    src="{{item.imgItem}}" 
    mode="aspectFill"
  />
  <view class="card-text">
    {{item.itemName}}
  </view>
</view>