<!-- components/selectCommunity/selectCommunity.wxml -->
<view class="tab-container">
  <view 
    class="tab-item {{curTab === index ? 'active' : ''}}"
    wx:for="{{tabData}}"
    wx:key="index"
    data-index="{{index}}"
    bindtap="handleTabClick"
  >
    {{item.name}}
  </view>
</view>