.container {
    padding: 20rpx;
    background: #f4f7ff;
    min-height: 100vh;
  }
  
  /* tabs */
  .tabs {
    display: flex;
    margin-bottom: 20rpx;
  }
  
  .tab {
    flex: 1;
    text-align: center;
    padding: 16rpx 0;
    background: #fff;
    border-radius: 20rpx;
    margin-right: 10rpx;
  }
  
  .tab.active {
    background: linear-gradient(135deg, #1677ff, #69a6ff);
    color: #fff;
  }
  
  /* 批量 */
  .batch-bar {
    background: #fff;
    padding: 16rpx;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
    display: flex;
    justify-content: space-between;
  }
  
  /* 卡片 */
  .card {
    display: flex;
    align-items: flex-start;
    background: #fff;
    padding: 20rpx;
    border-radius: 20rpx;
    margin-bottom: 16rpx;
  }
  
  .avatar {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    margin: 0 16rpx;
  }
  
  .info {
    flex: 1;
  }
  
  .name {
    font-weight: bold;
  }
  
  .phone {
    color: #888;
    font-size: 24rpx;
  }
  
  .reason {
    margin-top: 6rpx;
    font-size: 24rpx;
  }
  
  .time {
    font-size: 22rpx;
    color: #aaa;
  }
  
  /* 状态 */
  .status {
    margin-top: 6rpx;
    font-size: 22rpx;
  }
  
  .status.pending {
    color: #faad14;
  }
  
  .status.approved {
    color: #52c41a;
  }
  
  .status.rejected {
    color: #ff4d4f;
  }
  
  /* 操作 */
  .actions {
    margin-top: 10rpx;
    display: flex;
    gap: 10rpx;
  }