.container {
    padding: 40rpx 30rpx;
    background: #f5f7ff;
    min-height: 100vh;
  }
  
  .title {
    font-size: 36rpx;
    font-weight: bold;
    color: #1677ff;
  }
  
  .group-card {
    background: #fff;
    border-radius: 16rpx;
    margin-bottom: 24rpx;
    overflow: hidden;
    box-shadow: 0 8rpx 20rpx rgba(22,119,255,0.08);
  }
  
  .cover {
    width: 100%;
    height: 260rpx;
  }
  
  .info {
    padding: 20rpx;
  }
  
  .name {
    font-size: 30rpx;
    font-weight: 600;
  }
  
  .count {
    font-size: 24rpx;
    color: #888;
  }