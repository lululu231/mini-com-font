.photo-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10rpx;
  }
  .title {
    background: linear-gradient(135deg, #e6f0ff, #f5f9ff);
    padding: 40rpx 30rpx;
    text-align: center;
    font-size: 34rpx;
    font-weight: 600;
    color: #1677ff;
    border-radius: 12rpx;
  }
  .photo {
    width: 220rpx;
    height: 220rpx;
    border-radius: 10rpx;
  }