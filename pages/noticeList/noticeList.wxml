<!-- pages/noticeList/noticeList.wxml -->
<view class="container">

<!-- 置顶公告 -->
<view wx:if="{{topNotices.length}}" class="section">

  <view class="section-title">📌 置顶公告</view>

  <view 
    class="card top"
    wx:for="{{topNotices}}"
    wx:key="id"
    bindtap="toggleDetail"
    data-id="{{item.id}}"
  >
    <view class="header">
      <text class="title">{{item.title}}</text>
      <text class="badge">重要</text>
    </view>

    <view class="meta">
      <text>{{item.createTime}}</text>
      <text wx:if="{{!item.read}}" class="unread">未读</text>
    </view>

    <view wx:if="{{item.showDetail}}" class="content">
      {{item.content}}
    </view>
  </view>

</view>

<!-- 普通公告 -->
<view class="section">

  <view class="section-title">全部公告</view>

  <view wx:if="{{notices.length}}">

    <view 
      class="card"
      wx:for="{{notices}}"
      wx:key="id"
      bindtap="toggleDetail"
      data-id="{{item.id}}"
    >

      <view class="header">
        <text class="title">{{item.title}}</text>
      </view>

      <view class="meta">
        <text>{{item.createTime}}</text>
        <text wx:if="{{!item.read}}" class="unread">未读</text>
      </view>

      <view wx:if="{{item.showDetail}}" class="content">
        {{item.content}}
      </view>

    </view>

  </view>

  <!-- 空状态 -->
  <view wx:else class="empty">
    暂无公告
  </view>

</view>

</view>