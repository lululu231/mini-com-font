<view class="container">

<!-- 置顶公告 -->
<view wx:if="{{topNotices.length}}">
  <view class="section-title">📌 置顶公告</view>

  <view 
    class="card top"
    wx:for="{{topNotices}}"
    wx:key="id"
    data-id="{{item.id}}"
    bindtap="toggleDetail"
  >
    <view class="header">
      <text class="title">{{item.title}}</text>
      <text class="time">{{item.createTime}}</text>
    </view>

    <view wx:if="{{item.showDetail}}" class="content">
      {{item.content}}
    </view>

    <!-- 附件 -->
    <view wx:if="{{item.attachment}}" class="file">
      📎 附件：{{item.attachment}}
    </view>
  </view>
</view>

<!-- 普通公告 -->
<view class="section-title">📄 公告列表</view>

<view 
  class="card"
  wx:for="{{notices}}"
  wx:key="id"
  data-id="{{item.id}}"
  bindtap="toggleDetail"
>
  <view class="header">
    <text class="title">{{item.title}}</text>
    <text class="time">{{item.createTime}}</text>
  </view>

  <view wx:if="{{item.showDetail}}" class="content">
    {{item.content}}
  </view>

  <view wx:if="{{item.attachment}}" class="file">
    📎 附件：{{item.attachment}}
  </view>
</view>

</view>