.container {
    padding: 20rpx;
    background: #f4f7ff;
    min-height: 100vh;
  }
  
  .section {
    margin-bottom: 20rpx;
  }
  
  .section-title {
    font-size: 28rpx;
    font-weight: bold;
    margin-bottom: 16rpx;
    color: #333;
  }
  
  /* 卡片 */
  .card {
    background: #fff;
    border-radius: 20rpx;
    padding: 20rpx;
    margin-bottom: 16rpx;
    box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05);
  }
  
  /* 置顶样式 */
  .card.top {
    border: 2rpx solid #1677ff;
  }
  
  /* 头部 */
  .header {
    display: flex;
    justify-content: space-between;
  }
  
  .title {
    font-size: 28rpx;
    font-weight: 600;
    color: #2b2f36;
  }
  
  .badge {
    font-size: 20rpx;
    color: #1677ff;
  }
  
  /* 元信息 */
  .meta {
    margin-top: 10rpx;
    font-size: 22rpx;
    color: #999;
    display: flex;
    justify-content: space-between;
  }
  
  .unread {
    color: #ff4d4f;
  }
  
  /* 内容 */
  .content {
    margin-top: 16rpx;
    font-size: 24rpx;
    color: #444;
    line-height: 1.6;
  }
  
  /* 空状态 */
  .empty {
    text-align: center;
    color: #999;
    margin-top: 100rpx;
  }