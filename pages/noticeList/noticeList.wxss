.container {
    padding: 20rpx 20rpx 40rpx;
    background: #f4f7fb;
    min-height: 100vh;
    box-sizing: border-box;
  }
  
  /* 标题（更高级的弱化） */
  .section-title {
    font-size: 24rpx;
    font-weight: 500;
    color: #94a3b8;
    margin: 24rpx 12rpx 12rpx;
    letter-spacing: 1rpx;
  }
  
  /* 卡片（核心质感） */
  .card {
    background: #ffffff;
    border-radius: 20rpx;
    padding: 26rpx;
    margin: 0 8rpx 24rpx;
    width: 100%;
    box-shadow: 
      0 8rpx 24rpx rgba(15, 23, 42, 0.04),
      0 2rpx 8rpx rgba(15, 23, 42, 0.03);
  
    transition: all 0.2s ease;
  }
  
  /* 点击反馈 */
  .card:active {
    transform: scale(0.97);
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  }
  
  /* 置顶卡片（更克制高级蓝） */
  .card.top {
    background: linear-gradient(135deg, #f5f9ff, #ffffff);
    border: 1rpx solid rgba(59, 130, 246, 0.12);
  }
  
  /* header */
  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  
  /* 标题 */
  .title {
    font-size: 30rpx;
    font-weight: 600;
    color: #0f172a;
    line-height: 1.5;
    max-width: 70%;
  }
  
  /* 时间 */
  .time {
    font-size: 22rpx;
    color: #cbd5f5;
  }
  
  /* 内容 */
  .content {
    margin-top: 18rpx;
    font-size: 26rpx;
    color: #475569;
    line-height: 1.8;
  
    padding-top: 16rpx;
    border-top: 1rpx solid #f1f5f9;
  }
  
  /* 附件（更像标签） */
  .file {
    margin-top: 16rpx;
    font-size: 22rpx;
    color: #2563eb;
  
    background: rgba(37, 99, 235, 0.08);
    padding: 8rpx 18rpx;
    border-radius: 999rpx;
  
    display: inline-flex;
    align-items: center;
  }
  
  /* 置顶标签（优化） */
  .tag-top {
    display: inline-block;
    font-size: 20rpx;
    color: #2563eb;
    background: rgba(37, 99, 235, 0.12);
    padding: 4rpx 12rpx;
    border-radius: 999rpx;
    margin-right: 8rpx;
  }
  
  /* 微浮动（高级感来源） */
  .card:hover {
    transform: translateY(-2rpx);
  }