/* pages/memberManage/memberManage.wxss */

.container {
    padding: 30rpx;
    background: linear-gradient(180deg, #eaf2ff, #ffffff);
    min-height: 100vh;
  }
  
  /* 标题 */
  .title {
    font-size: 42rpx;
    font-weight: 700;
    margin-bottom: 20rpx;
    color: #1a1a1a;
  }
  
  /* 部门切换 */
  .dept-switch {
    margin-bottom: 24rpx;
  }
  
  .picker {
    background: #fff;
    padding: 22rpx;
    border-radius: 20rpx;
    box-shadow: 0 8rpx 24rpx rgba(74,144,226,0.08);
    color: #333;
  }
  
  /* 分区 */
  .section {
    margin-top: 30rpx;
  }
  
  .section-title {
    font-size: 30rpx;
    font-weight: 600;
    margin-bottom: 20rpx;
    color: #333;
  }
  
  /* 成员卡片 */
  .member-card {
    background: #fff;
    border-radius: 24rpx;
    padding: 22rpx;
    margin-bottom: 18rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.04);
  }
  
  /* 左侧 */
  .left {
    display: flex;
    align-items: center;
  }
  
  /* 头像 */
  .avatar {
    width: 90rpx;
    height: 90rpx;
    border-radius: 50%;
    margin-right: 20rpx;
  }
  
  /* 信息 */
  .info {
    display: flex;
    flex-direction: column;
  }
  
  .top {
    display: flex;
    align-items: center;
    gap: 10rpx;
  }
  
  .name {
    font-size: 28rpx;
    font-weight: 600;
    width: 60rpx;
    word-break: break-all;       /* ✅ 强制换行（关键） */
    overflow-wrap:break-word;   /* ✅ 兼容写法 */
  }
  
  /* 标签 */
  .tag {
    font-size: 20rpx;
    padding: 4rpx 12rpx;
    border-radius: 20rpx;
  }
  
  .role-president {
    background: #fff7e6;
    color: #fa8c16;
  }
  
  .role-leader {
    background: #e6f7ff;
    color: #1890ff;
  }
  
  .role-member {
    background: #f5f5f5;
    color: #999;
  }
  
  .meta {
    font-size: 22rpx;
    color: #999;
    margin-top: 6rpx;
  }
  
  /* 右侧按钮区 */
  .right {
    display: flex;
    gap: 12rpx;
  }
  
  /* 按钮基础 */
  .btn {
    padding: 10rpx 18rpx;
    border-radius: 24rpx;
    font-size: 22rpx;
  }
  
  /* 风格 */
  .primary {
    background: linear-gradient(135deg, #4a90e2, #6aa9ff);
    color: #fff;
  }
  
  .ghost {
    background: #f0f5ff;
    color: #4a90e2;
  }
  
  .danger {
    background: #fff1f0;
    color: #ff4d4f;
  }
  
  .small {
    font-size: 22rpx;
  }
  /* 遮罩 */
.modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  /* 弹窗 */
  .modal {
    width: 600rpx;
    background: #fff;
    border-radius: 20rpx;
    padding: 30rpx;
  }
  
  /* 标题 */
  .modal-title {
    font-size: 32rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
  }
  
  /* 部门列表 */
  .dept-item {
    padding: 20rpx;
    border-bottom: 1px solid #eee;
  }
  
  .dept-item.active {
    color: #1677ff;
    font-weight: bold;
  }
  
  /* 按钮区 */
  .modal-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 20rpx;
  }