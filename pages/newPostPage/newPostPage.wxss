/* pages/createPost/createPost.wxss */

.container {
    background: #f5f7fb;
    min-height: 100vh;
    padding: 30rpx;
  }
  .upload-container {
    display: flex;
    flex-wrap: wrap;
    gap: 20rpx;
  }
  
  .img-item {
    width: 200rpx;
    height: 200rpx;
    position: relative;
  }
  
  .preview {
    width: 100%;
    height: 100%;
    border-radius: 12rpx;
  }
  
  .upload-box {
    width: 200rpx;
    height: 200rpx;
    border: 2rpx dashed #ccc;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12rpx;
  }
  
  .upload-text {
    font-size: 60rpx;
    color: #999;
  }
  /* 卡片容器 */
  .card {
    background: #ffffff;
    border-radius: 20rpx;
    padding: 30rpx;
    box-shadow: 0 10rpx 30rpx rgba(100, 149, 237, 0.15);
  }
  
  /* 表单项 */
  .form-item {
    margin-bottom: 40rpx;
  }
  
  /* label */
  .label {
    font-size: 28rpx;
    color: #333;
    margin-bottom: 12rpx;
    display: block;
    font-weight: 600;
  }
  
  /* 输入框 */
  .input {
    height: 80rpx;
    border-radius: 12rpx;
    padding: 0 20rpx;
    border: 2rpx solid #e5eaf3;
    background: #f9fbff;
    transition: all 0.2s;
  }
  
  /* textarea */
  .textarea {
    min-height: 220rpx;
    border-radius: 12rpx;
    padding: 20rpx;
    border: 2rpx solid #e5eaf3;
    background: #f9fbff;
  }
  
  /* 选中态（重点视觉） */
  .input:focus,
  .textarea:focus {
    border-color: cornflowerblue;
    background: #ffffff;
  }
  
  /* picker */
  .picker {
    height: 80rpx;
    line-height: 80rpx;
    padding: 0 20rpx;
    border-radius: 12rpx;
    border: 2rpx dashed cornflowerblue;
    color: #666;
    background: #f4f8ff;
  }
  
  /* 上传区域 */
  .upload-box {
    width: 200rpx;
    height: 200rpx;
    border-radius: 16rpx;
    border: 2rpx dashed cornflowerblue;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f4f8ff;
    overflow: hidden;
  }
  
  /* 上传文字 */
  .upload-text {
    color: cornflowerblue;
    font-size: 28rpx;
  }
  
  /* 图片 */
  .preview {
    width: 100%;
    height: 100%;
  }
  
  /* 按钮 */
  .submit-btn {
    margin-top: 40rpx;
    height: 90rpx;
    border-radius: 50rpx;
    background: linear-gradient(135deg, cornflowerblue, #5a8dee);
    color: white;
    font-size: 32rpx;
    box-shadow: 0 8rpx 20rpx rgba(100, 149, 237, 0.4);
  }
  
  /* 按钮点击效果 */
  .submit-btn:active {
    transform: scale(0.96);
  }
