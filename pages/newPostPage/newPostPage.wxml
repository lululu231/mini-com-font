<!-- pages/createPost/createPost.wxml -->
<view class="container">

<view class="card">

  <!-- 标题 -->
  <view class="form-item">
    <text class="label">标题</text>
    <input 
      class="input"
      placeholder="请输入标题"
      bindinput="handleTitleInput"
    />
  </view>

  <!-- 内容 -->
  <view class="form-item">
    <text class="label">内容</text>
    <textarea 
      class="textarea"
      placeholder="分享点什么吧..."
      bindinput="handleContentInput"
    />
  </view>

  <!-- 社团选择 -->
  <view class="form-item">
    <text class="label">选择社团</text>
    <picker 
      mode="selector" 
      range="{{communityList}}" 
      range-key="name"
      bindchange="handleCommunityChange"
    >
      <view class="picker">
        {{selectedCommunityName || '点击选择社团'}}
      </view>
    </picker>
  </view>

  <!-- 图片上传 -->
  <view class="form-item">
    <text class="label">图片</text>

    <view class="upload-box" bindtap="handleUpload">
      <image 
        wx:if="{{imageUrl}}" 
        src="{{imageUrl}}" 
        class="preview"
      />
      <text wx:else class="upload-text">+ 添加图片</text>
    </view>
  </view>

</view>

<!-- 发布按钮 -->
<button class="submit-btn" bindtap="handleSubmit">
  发布帖子
</button>

</view>