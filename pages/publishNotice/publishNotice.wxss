.container {
    padding: 30rpx;
    background: linear-gradient(180deg, #eef3ff 0%, #f7f9ff 100%);
    min-height: 100vh;
  }
  
  /* 顶部标题 */
  .header {
    text-align: center;
    margin-bottom: 30rpx;
  }
  
  .title {
    font-size: 36rpx;
    font-weight: 600;
    color: #1677ff;
    letter-spacing: 2rpx;
  }
  
  /* 卡片容器 */
  .form-group {
    background: #fff;
    padding: 24rpx;
    border-radius: 16rpx;
    margin-bottom: 24rpx;
    box-shadow: 0 8rpx 20rpx rgba(22, 119, 255, 0.08);
    transition: all 0.2s ease;
  }
  
  /* label */
  .label {
    display: block;
    font-size: 26rpx;
    margin-bottom: 12rpx;
    color: #333;
    font-weight: 500;
  }
  
  /* 输入框 */
  .input, .textarea {
    /* width: 100%; */
    padding: 16rpx;
    border: 2rpx solid #e6ecff;
    border-radius: 10rpx;
    background: #fafbff;
    color: #333;
    font-size: 26rpx;
    transition: all 0.2s ease;
  }
  
  /* 输入框 focus 态（重点） */
  .input:focus, .textarea:focus {
    border-color: #1677ff;
    background: #fff;
    box-shadow: 0 0 0 2rpx rgba(22,119,255,0.1);
  }
  
  /* textarea */
  .textarea {
    height: 220rpx;
  }
  
  /* picker */
  .picker {
    padding: 16rpx;
    border: 2rpx solid #e6ecff;
    border-radius: 10rpx;
    background: #fafbff;
    color: #333;
    font-size: 26rpx;
  }
  
  /* 上传按钮 */
  .upload-btn {
    padding: 14rpx 28rpx;
    background: linear-gradient(135deg, #1677ff, #4096ff);
    color: #fff;
    border: none;
    border-radius: 999rpx;
    font-size: 24rpx;
    box-shadow: 0 6rpx 16rpx rgba(22, 119, 255, 0.25);
  }
  
  /* 文件名 */
  .file-name {
    margin-left: 16rpx;
    color: #666;
    font-size: 24rpx;
  }
  
  /* 发布按钮（主按钮） */
  .publish-btn {
    width: 100%;
    padding: 20rpx;
    background: linear-gradient(135deg, #1677ff, #4096ff);
    color: #fff;
    border: none;
    border-radius: 14rpx;
    font-size: 30rpx;
    font-weight: 600;
    letter-spacing: 2rpx;
    box-shadow: 0 10rpx 24rpx rgba(22, 119, 255, 0.3);
  }
  
  /* 点击反馈 */
  .publish-btn:active {
    transform: scale(0.98);
    box-shadow: 0 6rpx 12rpx rgba(22, 119, 255, 0.2);
  }